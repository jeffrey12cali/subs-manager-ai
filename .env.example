# --- Library ---
# Colon-separated absolute paths inside the api container.
LIBRARY_ROOTS=/library
# Where symlinks resolve to (mounted read-only is fine for scan, RW for embed).
RAW_ROOT=/your/path

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:////data/subs.db
DATA_DIR=/data
LOG_LEVEL=INFO

# --- Redis / worker ---
REDIS_URL=redis://redis:6379/0

# --- Whisper (CPU) ---
WHISPER_MODEL=small         # tiny|base|small|medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD=true

# --- Translator (DeepSeek via OpenAI-compat) ---
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
TRANSLATE_MODEL=deepseek-chat

# --- Web ---
# Docker Compose overrides this to http://api:8000 automatically.
# Only set this when running the Vite dev server locally (outside Docker).
# VITE_API_BASE=http://localhost:8000
