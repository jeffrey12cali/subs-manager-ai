# --- Library ---
# Colon-separated absolute paths INSIDE the api container to scan for movies.
# These must fall under a path that docker-compose.yml mounts into the
# container (see the api/worker `volumes:` section). Each path here becomes
# its own scan job when you click "Scan now" — don't add write-only paths
# here, use SAFE_FS_ROOTS below for those instead.
LIBRARY_ROOTS=/library

# Colon-separated extra paths the safe-fs write gate should allow, without
# being scanned. If your library uses symlinks with ABSOLUTE targets (e.g. a
# file in Movies points to /media/Raw/...), mount the whole tree at the
# IDENTICAL host path in docker-compose.yml so the links resolve, and declare
# the symlink-target dir here so embeds into it are permitted.
#   LIBRARY_ROOTS=/media/Movies
#   SAFE_FS_ROOTS=/media/Raw
SAFE_FS_ROOTS=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:////data/subs.db
DATA_DIR=/data
LOG_LEVEL=INFO

# --- Redis / worker ---
REDIS_URL=redis://redis:6379/0

# --- Whisper (CPU) ---
WHISPER_MODEL=small         # tiny|base|small|medium
WHISPER_COMPUTE_TYPE=int8
WHISPER_VAD=true

# --- Translator (DeepSeek via OpenAI-compat) ---
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
TRANSLATE_MODEL=deepseek-chat

# --- Web ---
# Docker Compose overrides this to http://api:8000 automatically.
# Only set this when running the Vite dev server locally (outside Docker).
# VITE_API_BASE=http://localhost:8000
